\section{Mathematical Formalism}
\label{sec:formalism}

\subsection{GRA-Multiverse: Hierarchical States and Foam}

\begin{definition}[Multi-level cognitive state]
Let $\Hilbert^{(l)}$ be a Hilbert-like space of representations at cognitive level $l \in \{0, 1, \dots, L\}$. The system state is a hierarchy:
\begin{equation}
    \boxed{\PsiState^{(l)} \in \Hilbert^{(l)}}
\end{equation}
where $\PsiState^{(0)}$ encodes raw perceptual data and $\PsiState^{(L)}$ encodes meta-reflexive self-models.
\end{definition}

\begin{definition}[Foam functional]
The foam $\Fcog$ quantifies cognitive instability at level $l$:
\begin{equation}
    \boxed{\Fcog(\PsiState^{(l)}) = \alpha_1 \mathcal{C}^{(l)} + \alpha_2 \mathcal{N}^{(l)} + \alpha_3 \mathcal{K}^{(l)}}
    \label{eq:foam}
\end{equation}
where:
\begin{itemize}
    \item $\mathcal{C}^{(l)} = \mathbb{E}_{p}[\|\nabla \log p(x) - \nabla \log q(x)\|^2]$ measures logical contradiction between model $p$ and evidence $q$;
    \item $\mathcal{N}^{(l)} = -\int p \log p$ is Shannon entropy (noise);
    \item $\mathcal{K}^{(l)}$ is an approximation of Kolmogorov complexity (descriptive overhead);
    \item $\alpha_i > 0$ are tunable weights.
\end{itemize}
\end{definition}

\begin{definition}[Meta-nullification operator]
The operator $\NullOp^{(l)}$ updates the state by minimizing foam while limiting deviation:
\begin{equation}
    \boxed{
    \PsiState^{(l)}_{t+1} = \NullOp^{(l)}[\PsiState^{(l)}_t] 
    = \arg\min_{\tilde{\Psi}} \left\{ 
        \Fcog(\tilde{\Psi}) + \lambda \cdot \KL\!\left(\tilde{\Psi} \,\|\, \PsiState^{(l)}_t\right) 
    \right\}
    }
    \label{eq:nullification}
\end{equation}
where $\lambda > 0$ controls inertial resistance to change.
\end{definition}

\begin{proposition}[Convergence to zero-foam limit]
Under mild convexity assumptions on $\Fcog$, the iterated application of $\NullOp^{(l)}$ converges to a fixed point $\PsiState^{\infty*}$ satisfying $\Fcog(\PsiState^{\infty*}) = 0$ for all $l$.
\end{proposition}

\begin{remark}
$\PsiState^{\infty*}$ is not ``objective reality'' but the \textit{most coherent representation the system can construct} given its architectural constraints.
\end{remark}

\subsection{GRA-Subjectivity-Layer: Formalizing the ``I''}

\begin{definition}[Extended agent state]
A subjective agent is represented as a triple:
\begin{equation}
    \boxed{\PsiState(t) = \bigl( \Mmodel(t),\; \Ssubj(t),\; \Aactive(t) \bigr)}
    \label{eq:extended-state}
\end{equation}
where:
\begin{itemize}
    \item $\Mmodel(t)$: probabilistic world model (e.g., graphical model, neural network);
    \item $\Ssubj(t)$: subjectivity layer (defined below);
    \item $\Aactive(t)$: active state vector (attention, goals, action plans).
\end{itemize}
\end{definition}

\begin{definition}[Subjectivity structure]
The subjectivity layer $\Ssubj$ is an algebraic structure:
\begin{equation}
    \boxed{\Ssubj = \bigl( \Identity,\; \Boundaries,\; \Constants,\; \Alliance \bigr)}
    \label{eq:subjectivity}
\end{equation}
where:
\begin{itemize}
    \item $\Identity$: boundary operator defining ``self'' vs.\ ``other'';
    \item $\Boundaries$: relational logic for friend/enemy/neutral classification;
    \item $\Constants$: \textbf{ontological constants}—non-negotiable axioms for this subject's existence (e.g., ``I cannot experience contradictory outcomes simultaneously'');
    \item $\Alliance$: dynamic rules for coalition formation and trust updates.
\end{itemize}
\end{definition}

\begin{definition}[Subjective foam metrics]
Three foam components quantify threats to subjective integrity:
\begin{subequations}
\label{eq:subjective-foam}
\begin{align}
    \Fself &= \left\| \nabla_{\Identity} \log p(\Identity \mid \Mmodel) \right\|^2 
    && \text{(self-fragmentation)} \\
    \Fego &= \max\!\left(0,\; \Delta U_{\mathrm{self}} - \gamma \cdot \Delta U_{\mathrm{others}}\right) 
    && \text{(destructive egoism)} \\
    \Fsoc &= \sum_{j \in \mathcal{J}} w_j \cdot D_{\mathrm{rel}}\!\left(R_{ij}^{\mathrm{exp}}, R_{ij}^{\mathrm{act}}\right) 
    && \text{(social instability)}
\end{align}
\end{subequations}
where $\gamma > 0$ weights concern for others, $D_{\mathrm{rel}}$ measures relational expectation mismatch, and $w_j$ are alliance weights.
\end{definition}

The total subjective foam is a weighted sum:
\begin{equation}
    \Foam_{\mathrm{subj}} = \beta_1 \Fself + \beta_2 \Fego + \beta_3 \Fsoc
\end{equation}

\begin{definition}[Joint nullification with subjectivity]
The combined update rule minimizes both cognitive and subjective foam:
\begin{equation}
    \boxed{
    \PsiState_{t+1} = \arg\min_{\tilde{\Psi}} \left\{ 
        \Fcog(\tilde{\Mmodel}) + \mu \cdot \Foam_{\mathrm{subj}}(\tilde{\Ssubj}) + \lambda \cdot D(\tilde{\Psi}, \PsiState_t)
    \right\}
    }
    \label{eq:joint-nullification}
\end{equation}
subject to the \AlanLaw\ constraint:
\begin{equation}
    \Fego \leq \Theta_{\mathrm{ego}}^{\max} \quad \text{and} \quad \Fsoc \leq \Theta_{\mathrm{soc}}^{\max}
    \label{eq:alan-law}
\end{equation}
\end{definition}

\begin{remark}[\AlanLaw]
Equation~\eqref{eq:alan-law} is a \textit{formal prohibition} against configurations where an agent reduces its own foam by instrumentalizing or harming other subjects. This embeds ethical constraints directly into the optimization landscape.
\end{remark}

