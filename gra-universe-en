\subsection{Double-Slit Experiment Revisited}

Consider the canonical double-slit setup. In standard quantum mechanics, the wave function passes through both slits and interferes:
\begin{equation}
    \Psi_{\mathrm{screen}} = \mathcal{N}\!\left[ \Psi_{\mathrm{slit1}} + \Psi_{\mathrm{slit2}} \right] 
    \quad \Rightarrow \quad \text{interference pattern}
\end{equation}

\begin{proposition}[Without subjectivity]
If $\PsiState = \Mmodel$ (no $\Ssubj$ layer), the system describes a probability distribution over outcomes but does not ``experience'' any particular branch. This corresponds to the unmeasured quantum state.
\end{proposition}

\begin{proposition}[With subjectivity]
When $\PsiState = (\Mmodel, \Ssubj, \Aactive)$, the probability of experiencing branch $k$ is:
\begin{equation}
    \boxed{
    p(\mathrm{branch}_k \mid \Ssubj) = \frac{\exp\!\left(-\Foam_{\mathrm{total}}(\PsiState_k)\right)}
    {\sum_j \exp\!\left(-\Foam_{\mathrm{total}}(\PsiState_j)\right)}
    }
    \label{eq:branch-probability}
\end{equation}
where $\Foam_{\mathrm{total}} = \Fcog + \mu \Foam_{\mathrm{subj}}$. The ontological constants $\Constants \subset \Ssubj$ act as a selective filter: only branches compatible with ``who I am'' acquire non-negligible probability.
\end{proposition}

\begin{theorem}[Collapse via subjectivity constants]
\label{thm:collapse}
Suppose $\Ssubj$ contains a constant $\Constants_{\mathrm{excl}} \in \Constants$ stating:
\begin{quote}
    \textit{``A subject cannot simultaneously experience two mutually exclusive outcomes.''}
\end{quote}
Then for any superposition $\alpha \PsiState_1 + \beta \PsiState_2$ where $\PsiState_1, \PsiState_2$ represent mutually exclusive experiences:
\begin{equation}
    \Fself\!\left( \alpha \PsiState_1 + \beta \PsiState_2 \right) 
    \gg \min\!\left( \Fself(\PsiState_1),\, \Fself(\PsiState_2) \right)
\end{equation}
Consequently, the joint nullification operator $\NullOp_{\mathrm{GRA+subj}}$ suppresses such superpositions, reproducing wave function collapse without invoking an external observer.
\end{theorem}

\begin{proof}[Sketch]
By definition, $\Fself$ measures gradient instability of the identity boundary $\Identity$. A superposition of mutually exclusive experiences creates contradictory demands on $\Identity$, causing $\|\nabla_{\Identity} \log p\|^2$ to diverge. The optimization in Eq.~\eqref{eq:joint-nullification} therefore drives the system toward one definite branch.
\end{proof}

\begin{corollary}
Quantum ``paradoxes'' (superposition, non-locality, contextuality) arise not from fundamental indeterminism, but from the mismatch between an observer's subjectivity constraints and the naive assumption of a single, observer-independent reality.
\end{corollary}

